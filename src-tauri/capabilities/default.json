{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "dialog:default",
    "fs:default",
    "fs:read-all",
    "opener:default",
    "autostart:default"
  ]
}
