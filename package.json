{
  "name": "tino",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm gen:bindings && vite",
    "gen:bindings": "cargo run --manifest-path src-tauri/Cargo.toml --bin generate_bindings",
    "build": "pnpm gen:bindings && tsc -b && vite build",
    "typecheck": "pnpm gen:bindings && tsc -b",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check": "pnpm lint && pnpm typecheck && pnpm check:rust",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
